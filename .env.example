
# API Key cho LLM provider (OpenAI, vLLM, Ollama, NVIDIA, etc.)
OPENAI_API_KEY=your_api_key_here

# Base URL của LLM API server
# Ví dụ:
#   - OpenAI: https://api.openai.com/v1
#   - Ollama local: http://localhost:11434/v1
#   - vLLM: http://your-vllm-server:8000/v1
#   - NVIDIA: https://integrate.api.nvidia.com/v1
OPENAI_API_BASE=https://api.openai.com/v1

# Tên model sử dụng
# Ví dụ:
#   - OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
#   - Ollama: qwen2.5:32b, llama3.1:8b
#   - NVIDIA: qwen/qwen3.5-122b-a10b
OPENAI_MODEL=gpt-4o

# Temperature: 0.0-1.0 (cao = sáng tạo hơn, thấp = chắc chắn hơn)
OPENAI_TEMPERATURE=0.6

# Top_P: 0.0-1.0 (sampling probability threshold)
OPENAI_TOP_P=0.9

# Timeout cho LLM API calls (seconds)
LLM_TIMEOUT=120

# Số lần retry tối đa khi gọi API
LLM_MAX_RETRIES=3


# ==============================================================================
# 🌐 BROWSER / CDP CONFIGURATION
# ==============================================================================

# Chrome DevTools Protocol URL
# Khi chạy trong Docker:
#   - Kết nối tới chrome-cdp service: http://chrome-cdp:3000
#   - Kết nối tới Chrome trên host: http://host.docker.internal:9223
# Khi chạy local (Python trực tiếp):
#   - http://127.0.0.1:9223
CHROME_CDP_URL=http://chrome-cdp:3000

# CDP remote debugging port (chỉ dùng khi chạy local)
CHROME_CDP_PORT=9223

# Có sử dụng vision capabilities không (true/false)
BROWSER_USE_VISION=false

# Số bước tối đa cho agent run
BROWSER_MAX_STEPS=50


# ==============================================================================
# 🏃 AGENT RUNTIME CONFIGURATION
# ==============================================================================

# Timeout cho mỗi action (seconds)
BROWSER_USE_ACTION_TIMEOUT=120

# Timeout cho watchdog (seconds)
BROWSER_USE_WATCHDOG_TIMEOUT=120

# Có bật telemetry không (true/false) - Khuyến nghị: false
BROWSER_USE_TELEMETRY=false

# Có bật anonymized telemetry không (true/false) - Khuyến nghị: false
ANONYMIZED_TELEMETRY=false


# ==============================================================================
# 🖥️ SERVER CONFIGURATION
# ==============================================================================

# Server host
SERVER_HOST=0.0.0.0

# Server port
SERVER_PORT=5555

# Có bật auto-reload không (chỉ dùng cho development) (true/false)
SERVER_RELOAD=false

# Số lượng workers
SERVER_WORKERS=1

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# ==============================================================================
# 📊 PAPERLESS-NGX CONFIGURATION
# ==============================================================================

# Base URL của Paperless-ngx instance
# Ví dụ: http://localhost:8000, https://paperless.yourdomain.com
PAPERLESS_BASE_URL=

# Username cho Paperless-ngx
PAPERLESS_USERNAME=

# Password cho Paperless-ngx
PAPERLESS_PASSWORD=

# API token cho Paperless-ngx (nếu dùng token auth thay vì username/password)
PAPERLESS_API_TOKEN=

# Timeout cho Paperless API calls (seconds)
PAPERLESS_TIMEOUT=30

# Có xác thực SSL certificate không (true/false)
PAPERLESS_VERIFY_SSL=true


# ==============================================================================
# 🏦 SEABANK DOMAIN CONFIGURATION
# ==============================================================================

# URL của hệ thống văn bản Seabank
SEABANK_DOCUMENT_URL=https://vanban.seabank.com.vn

# Có yêu cầu login không (true/false)
SEABANK_LOGIN_REQUIRED=true

# Username mặc định cho Seabank systems (nếu có)
SEABANK_DEFAULT_USERNAME=

# Password mặc định cho Seabank systems (nếu có)
SEABANK_DEFAULT_PASSWORD=


# ==============================================================================
# 📝 NOTES
# ==============================================================================
# 
# 1. Để khởi động Chrome với remote debugging port, chạy:
#    - Windows: start_chrome_cdp_9223.bat
#    - Manual: chrome.exe --remote-debugging-port=9223 --user-data-dir="path/to/profile"
#
# 2. Khi chạy Docker, đảm bảo chrome-cdp service đang chạy:
#    docker-compose up -d chrome-cdp
#
# 3. Kiểm tra kết nối CDP:
#    curl http://localhost:9223/json/version
#
# 4. Để thay đổi model LLM, sửa OPENAI_MODEL và OPENAI_API_BASE
#
# ==============================================================================
